# Copy to .env.local and fill in. Never commit real keys.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# MySQL: copy to `.env` (not `.env.local`). Prisma CLI only auto-loads `.env`.
# Next.js loads both; keep DATABASE_URL in `.env` so `npx prisma db push` works.
# Example: mysql://root:password@127.0.0.1:3306/partselect_db

# Optional — `npx prisma db seed` (see `prisma/seed.mjs`):
# - Parts: repo `../data/all_parts.csv` if present (or ALL_PARTS_CSV)
# - Repairs: repo `../data/all_repairs.csv` if present (or ALL_REPAIRS_CSV); else guides from JSON
# - Compat: `web/data/catalog.json` when using parts CSV
# CATALOG_SEED_PATH=...           # full JSON (overrides parts CSV)
# ALL_PARTS_CSV=../data/all_parts.csv
# ALL_REPAIRS_CSV=../data/all_repairs.csv
# SEED_SKIP_CSV=1                 # skip parts CSV
# SEED_SKIP_REPAIR_CSV=1          # skip repairs CSV, keep JSON guides
